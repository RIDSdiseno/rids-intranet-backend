generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AccesoRouterSucursal {
  id         Int     @id @default(autoincrement())
  sucursalId Int
  url        String?
  usuario    String?
  secretoRef String?
  notas      String?

  @@index([sucursalId])
}

model ChatLog {
  id        Int      @id @default(autoincrement())
  phone     String
  role      String   @default("user")
  text      String
  createdAt DateTime @default(now())
}

model ChecklistGestionEmpresa {
  id                   Int     @id @default(autoincrement())
  fichaEmpresaId       Int     @unique
  levantamientoEquipos Boolean @default(false)
  inventarioSoftware   Boolean @default(false)
  soporteComputacional Boolean @default(false)
  sitiosWeb            Boolean @default(false)
  visitasPresenciales  Boolean @default(false)
  contratoFirmado      Boolean @default(false)
  facturasArchivadas   Boolean @default(false)
  historialIncidencias Boolean @default(false)
  reunionesRevision    Boolean @default(false)
  registroAccesos      Boolean @default(false)
  metasDigitales       Boolean @default(false)
  planAccion           Boolean @default(false)

  @@index([fichaEmpresaId])
}

model ContactoEmpresa {
  id        Int     @id @default(autoincrement())
  empresaId Int
  nombre    String
  cargo     String
  email     String?
  telefono  String?
  principal Boolean @default(false)

  @@index([empresaId])
}

model CotizacionGestioo {
  id                    Int                     @id @default(autoincrement())
  fecha                 DateTime                @default(now())
  estado                EstadoCotizacionGestioo @default(BORRADOR)
  tipo                  TipoCotizacionGestioo   @default(CLIENTE)
  entidadId             Int?
  total                 Float                   @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  iva                   Float                   @default(0)
  moneda                MonedaGestioo           @default(CLP)
  subtotal              Float                   @default(0)
  descuentos            Float                   @default(0)
  tasaCambio            Float?
  comentariosCotizacion String?
  personaResponsable    String?
  imagen                String?

  @@index([entidadId])
}

model CotizacionItemGestioo {
  id                Int             @id @default(autoincrement())
  cotizacionId      Int
  tipo              ItemTipoGestioo
  descripcion       String?
  cantidad          Int             @default(1)
  precio            Float           @default(0)
  porcentaje        Float?
  createdAt         DateTime        @default(now())
  sku               String?
  tieneIVA          Boolean         @default(false)
  tieneDescuento    Boolean         @default(false)
  imagen            String?
  porcGanancia      Float?
  precioCosto       Float?
  nombre            String?
  precioOriginalCLP Float?
}

model DetalleEquipo {
  id_detalle_equipo Int     @id @default(autoincrement())
  idEquipo          Int
  macWifi           String?
  so                String?
  tipoDd            String?
  estadoAlm         String?
  office            String?
  teamViewer        String?
  claveTv           String?
  revisado          String?

  @@index([idEquipo])
}

model DetalleTrabajoGestioo {
  id              Int              @id @default(autoincrement())
  fecha           DateTime         @default(now())
  tipoTrabajo     String
  descripcion     String?
  estado          String?          @default("pendiente")
  notas           String?
  area            AreaGestioo      @default(ENTRADA)
  prioridad       PrioridadGestioo @default(NORMAL)
  entidadId       Int?
  productoId      Int?
  servicioId      Int?
  equipoId        Int?
  tecnicoId       Int?
  incluyeCargador Boolean          @default(false)
  fechaIngreso    DateTime?
  ordenGrupoId    Int?

  @@index([entidadId])
  @@index([productoId])
  @@index([servicioId])
  @@index([tecnicoId])
}

model Empresa {
  id_empresa      Int      @id @default(autoincrement())
  nombre          String   @unique
  tieneSucursales Boolean  @default(false)
  razonSocial     String?
  dominios        String[] @default([])
}

model EmpresaISP {
  id           Int      @id @default(autoincrement())
  empresaId    Int      @unique
  operador     String?
  telefono     String?
  servicio     String?
  numeroTicket String?
  wifiNombre   String?
  wifiClaveRef String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  ipRed        String?
}

model EntidadGestioo {
  id        Int                @id @default(autoincrement())
  nombre    String
  rut       String?            @unique
  correo    String?
  telefono  String?
  direccion String?
  tipo      TipoEntidadGestioo @default(EMPRESA)
  origen    OrigenGestioo      @default(RIDS)
}

model Entrega {
  id_entrega     Int      @id @default(autoincrement())
  empresaNombre  String
  receptorNombre String
  fecha          DateTime @default(now())
  tecnicoId      Int?

  @@index([tecnicoId])
}

model Equipo {
  id_equipo     Int        @id @default(autoincrement())
  idSolicitante Int?
  serial        String?    @unique
  marca         String
  modelo        String
  procesador    String?
  ram           String?
  disco         String?
  propiedad     String     @default("ASUR")
  tipo          TipoEquipo @default(GENERICO)

  @@index([idSolicitante])
}

model EvidenciaEntrega {
  id        Int                  @id @default(autoincrement())
  entregaId Int
  tipo      TipoEvidenciaEntrega
  url       String
  publicId  String               @unique
  formato   String
  bytes     Int
  creadoEn  DateTime             @default(now())

  @@index([entregaId])
  @@index([tipo])
}

model FdSourceMap {
  id          Int     @id @default(autoincrement())
  companyId   BigInt? @unique
  domain      String? @unique
  ticketOrgId Int

  @@index([ticketOrgId])
}

model FichaEmpresa {
  id                     Int      @id @default(autoincrement())
  empresaId              Int      @unique
  creadaEn               DateTime @default(now())
  actualizadaEn          DateTime
  condicionesComerciales String?
}

model FichaTecnicaEmpresa {
  id                      Int       @id @default(autoincrement())
  empresaId               Int       @unique
  tecnicoPrincipal        String?
  tecnicosRespaldo        String?
  observacionesVisita     String?
  sistemasOperativos      String?
  proveedorInternet       String?
  dominioWeb              String?
  redesSociales           String?
  metodoRespaldo          String?
  frecuenciaRespaldo      String?
  responsableRespaldo     String?
  ultimaRestauracion      DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime
  antivirusSeguridad      String?
  aplicacionesCriticas    String?
  certificadoSSL          String?
  configuracionIP         String?
  correosCorporativos     String?
  fechaUltimaVisita       DateTime?
  hostingProveedor        String?
  impresorasPerifericos   String?
  licenciasVigentes       String?
  otrosEquipos            String?
  pcsNotebooks            String?
  proximaVisitaProgramada DateTime?
  routersSwitches         String?
  servidores              String?
  velocidadContratada     String?
}

model Firma {
  id            Int      @id @default(autoincrement())
  path          String
  mimeType      String?
  size          Int?
  createdAt     DateTime @default(now())
  solicitanteId Int?     @unique
  tecnicoId     Int?     @unique

  @@index([solicitanteId])
  @@index([tecnicoId])
}

model FreshdeskCompanyMap {
  companyId BigInt  @id
  empresaId Int
  domain    String?

  @@index([domain])
  @@index([empresaId])
}

model FreshdeskRequesterMap {
  requesterId   BigInt @id
  solicitanteId Int
  empresaId     Int

  @@index([empresaId])
  @@index([solicitanteId])
}

model FreshdeskTicket {
  id                BigInt    @id
  subject           String
  status            Int
  priority          Int
  type              String?
  requesterEmail    String?
  createdAt         DateTime
  updatedAt         DateTime
  source            String?
  capturedAt        DateTime?
  empresaId         Int?
  solicitanteId     Int?
  ticketOrgId       Int?
  ticketRequesterId Int?

  @@index([createdAt])
  @@index([empresaId])
  @@index([requesterEmail])
  @@index([solicitanteId])
  @@index([ticketOrgId])
  @@index([ticketRequesterId])
}

model Historial {
  tecnicoId          Int
  solicitante        String
  inicio             DateTime
  fin                DateTime
  realizado          String?
  solicitanteId      Int
  actualizaciones    Boolean  @default(false)
  antivirus          Boolean  @default(false)
  ccleaner           Boolean  @default(false)
  estadoDisco        Boolean  @default(false)
  licenciaOffice     Boolean  @default(false)
  licenciaWindows    Boolean  @default(false)
  mantenimientoReloj Boolean  @default(false)
  rendimientoEquipo  Boolean  @default(false)
  id_historial       Int      @id @default(autoincrement())
  direccion_visita   String?
  ecografo           Boolean  @default(false)
  sucursalId         Int?
  empresaId          Int?

  @@index([empresaId])
  @@index([solicitanteId])
  @@index([sucursalId])
  @@index([tecnicoId, fin(sort: Desc)])
}

model MarcaGestioo {
  id     Int    @id @default(autoincrement())
  nombre String
}

model ModeloGestioo {
  id      Int    @id @default(autoincrement())
  nombre  String
  marcaId Int

  @@index([marcaId])
}

model MsSku {
  skuId         String  @id
  skuPartNumber String
  displayName   String?
}

model ProductoGestioo {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  tipo          String    @default("producto")
  categoria     String?
  serie         String?   @unique
  estado        String?   @default("disponible")
  precio        Float?
  stock         Int?      @default(0)
  fechaIngreso  DateTime? @default(now())
  garantiaMeses Int?
  activo        Boolean   @default(true)
  marcaId       Int?
  modeloId      Int?
  entidadId     Int?
  porcGanancia  Float?
  precioTotal   Float?
  imagen        String?
  publicId      String?

  @@index([entidadId])
  @@index([marcaId])
  @@index([modeloId])
}

model RedSucursal {
  id            Int     @id @default(autoincrement())
  sucursalId    Int     @unique
  wifiNombre    String?
  claveWifi     String?
  ipRed         String?
  gateway       String?
  observaciones String?
}

model RefreshToken {
  id                Int       @id @default(autoincrement())
  userId            Int
  rtHash            String
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId Int?
  userAgent         String?
  ip                String?

  @@index([rtHash])
  @@index([userId])
}

model ResponsableSucursal {
  id         Int     @id @default(autoincrement())
  sucursalId Int
  nombre     String
  cargo      String
  email      String?
  telefono   String?

  @@index([sucursalId])
}

model ServicioGestioo {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  tipo          String    @default("servicio")
  categoria     String?
  precio        Float?
  duracionHoras Float?
  estado        String?   @default("disponible")
  activo        Boolean   @default(true)
  fechaCreacion DateTime? @default(now())
  entidadId     Int?

  @@index([entidadId])
}

model Solicitante {
  id_solicitante  Int          @id @default(dbgenerated("nextval((pg_get_serial_sequence('\"Solicitante\"'::text, 'id_solicitante'::text))::regclass)"))
  nombre          String
  email           String?
  telefono        String?
  empresaId       Int
  clienteId       Int?         @unique
  googleUserId    String?      @unique
  isActive        Boolean      @default(true)
  microsoftUserId String?      @unique
  accountType     AccountType?

  @@index([accountType])
  @@index([empresaId])
  @@index([isActive])
}

model SolicitanteMsLicense {
  id            Int       @id @default(autoincrement())
  solicitanteId Int
  skuId         String
  assignedAt    DateTime? @default(now())

  @@unique([solicitanteId, skuId])
  @@index([skuId])
  @@index([solicitanteId])
}

model Sucursal {
  id_sucursal Int     @id @default(autoincrement())
  nombre      String
  direccion   String?
  telefono    String?
  empresaId   Int

  @@index([empresaId])
}

model Tecnico {
  id_tecnico   Int     @id @default(autoincrement())
  nombre       String
  email        String  @unique
  passwordHash String
  status       Boolean @default(true)
}

model Ticket {
  id              Int            @id @default(autoincrement())
  empresaId       Int
  requesterId     Int?
  assigneeId      Int?
  subject         String
  status          TicketStatus   @default(NEW)
  priority        TicketPriority @default(NORMAL)
  channel         TicketChannel  @default(WEB)
  fromEmail       String?
  inboxEmail      String?
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  lastActivityAt  DateTime       @default(now())
  publicId        String         @unique

  @@index([assigneeId])
  @@index([createdAt])
  @@index([empresaId])
  @@index([status])
}

model TicketAdjunto {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  path      String
  fileName  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

model TicketAttachment {
  id        Int      @id @default(autoincrement())
  messageId Int
  filename  String
  mimeType  String
  url       String
  bytes     Int
  createdAt DateTime @default(now())
  contentId String?
  isInline  Boolean  @default(false)

  @@index([contentId])
  @@index([messageId])
}

model TicketEvent {
  id        Int             @id @default(autoincrement())
  ticketId  Int
  type      TicketEventType
  oldValue  String?
  newValue  String?
  actorType TicketActorType
  actorId   Int?
  createdAt DateTime        @default(now())

  @@index([ticketId])
}

model TicketMessage {
  id               Int              @id @default(autoincrement())
  ticketId         Int
  direction        MessageDirection
  isInternal       Boolean          @default(false)
  bodyText         String?
  bodyHtml         String?
  fromEmail        String?
  toEmail          String?
  cc               String?
  sourceMessageId  String?          @unique
  sourceInReplyTo  String?
  sourceReferences String?
  createdAt        DateTime         @default(now())

  @@index([createdAt])
  @@index([ticketId])
}

model TicketOrg {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model TicketRequester {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?  @unique
  phone         String?
  fdRequesterId BigInt?  @unique
  ticketOrgId   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([ticketOrgId])
}

model Visita {
  id_visita          Int          @id @default(autoincrement())
  empresaId          Int
  tecnicoId          Int
  solicitante        String
  inicio             DateTime
  fin                DateTime?
  confImpresoras     Boolean      @default(false)
  confTelefonos      Boolean      @default(false)
  confPiePagina      Boolean      @default(false)
  otros              Boolean      @default(false)
  otrosDetalle       String?
  status             EstadoVisita @default(PENDIENTE)
  solicitanteId      Int?
  actualizaciones    Boolean      @default(false)
  antivirus          Boolean      @default(false)
  ccleaner           Boolean      @default(false)
  estadoDisco        Boolean      @default(false)
  licenciaOffice     Boolean      @default(false)
  licenciaWindows    Boolean      @default(false)
  mantenimientoReloj Boolean      @default(false)
  rendimientoEquipo  Boolean      @default(false)
  direccion_visita   String?
  ecografo           Boolean      @default(false)
  sucursalId         Int?

  @@index([empresaId])
  @@index([solicitanteId])
  @@index([sucursalId])
  @@index([tecnicoId])
}

model detalle_empresas {
  id         Int     @id @default(autoincrement())
  rut        String  @unique
  direccion  String?
  telefono   String?
  email      String?
  empresa_id Int     @unique
}

enum AccountType {
  google
  microsoft
}

enum Area {
  entrada
  domicilio
  reparacion
  salida
}

enum AreaGestioo {
  ENTRADA
  DOMICILIO
  REPARACION
  SALIDA
}

enum EstadoCotizacionGestioo {
  BORRADOR
  GENERADA
  ENVIADA
  APROBADA
  RECHAZADA
}

enum EstadoTrabajoGestioo {
  PENDIENTE
  EN_PROCESO
  FINALIZADO
  CANCELADO
}

enum EstadoVisita {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

enum ItemTipoGestioo {
  PRODUCTO
  SERVICIO
  ADICIONAL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MonedaGestioo {
  CLP
  USD
}

enum OrigenGestioo {
  RIDS
  ECONNET
  OTRO
}

enum Prioridad {
  baja
  normal
  alta
}

enum PrioridadGestioo {
  BAJA
  NORMAL
  ALTA
}

enum TicketActorType {
  REQUESTER
  AGENT
  SYSTEM
}

enum TicketChannel {
  WEB
  EMAIL
  API
}

enum TicketEventType {
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  CREATED
  CLOSED
  REOPENED
  MESSAGE_SENT
  INTERNAL_NOTE
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TipoCotizacionGestioo {
  CLIENTE
  INTERNA
  PROVEEDOR
}

enum TipoEntidadGestioo {
  PERSONA
  EMPRESA
}

enum TipoEquipo {
  GENERICO
  NOTEBOOK
  ALL_IN_ONE
  DESKTOP
  CPU
  EQUIPO_ARMADO
  IMPRESORA
  SCANNER
  LASER
  LED
  MONITOR
  NAS
  ROUTER
  DISCO_DURO_EXTERNO
  CARGADOR
  INSUMOS_COMPUTACIONALES
  RELOJ_CONTROL
  OTRO
}

enum TipoEvidenciaEntrega {
  FOTO
  FIRMA
}
